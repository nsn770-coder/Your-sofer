rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    // Check that the caller is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Check admin status via the admins collection (primary) or users.role (fallback).
    // AuthContext uses admins/{uid} as the source of truth; Firestore rules must match.
    function isAdmin() {
      return isSignedIn()
        && (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          )
        );
    }

    // Check that the caller has role "shaliach" in their users document
    function isShaliach() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'shaliach';
    }

    // ── Public shop data ────────────────────────────────────────────────────

    match /products/{id} {
      allow read: if true;                // anyone can browse products
      allow write: if isAdmin();
    }

    match /soferim/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /klafim/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /shluchim/{id} {
      allow read: if true;
      allow write: if isAdmin();
      // Shluchim document owner can update only their own logoUrl
      allow update: if isSignedIn()
                    && request.auth.uid == id
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['logoUrl']);
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /curations/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /reviews/{id} {
      allow read: if true;
      allow create: if isSignedIn();      // logged-in users can submit reviews
      allow update, delete: if isAdmin();
    }

    // ── Homepage configuration (admin-only writes) ──────────────────────────

    match /homepageConfig/{id} {
      allow read: if true;               // homepage reads config publicly
      allow write: if isAdmin();         // only admins can pin products
    }

    // ── Settings (popup toggles, site config) ───────────────────────────────

    match /settings/{id} {
      allow read: if true;               // popups and config read publicly
      allow write: if isAdmin();
    }

    // ── User accounts ───────────────────────────────────────────────────────

    match /users/{userId} {
      allow read:   if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Admins collection (uid → exists check used for role bootstrap)
    match /admins/{userId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Orders ──────────────────────────────────────────────────────────────

    match /orders/{orderId} {
      // Signed-in users or guests who include a guestId string can create orders
      allow create: if isSignedIn()
                    || request.resource.data.guestId is string;
      // Guest orders (guestId present) are readable/updatable by anyone with the orderId.
      // The 20-char random Firestore ID acts as an unguessable access token.
      allow read:   if isAdmin()
                    || resource.data.guestId is string
                    || (isShaliach()
                        && resource.data.shaliachId ==
                           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shaliachId)
                    || (isSignedIn()
                        && resource.data.shaliachId == request.auth.uid
                        && exists(/databases/$(database)/documents/shluchim/$(request.auth.uid)));
      allow update: if isAdmin()
                    || resource.data.guestId is string;
      allow delete: if isAdmin();
    }

    // ── Order line items (sofer dashboard reads by soferId) ─────────────────

    match /orderItems/{id} {
      allow read: if isAdmin()
                  || (isSignedIn()
                      && resource.data.soferId != null
                      && resource.data.soferId ==
                         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.soferId);
      allow write: if isAdmin();
    }

    // ── Abandoned carts (anyone can write, admin reads/deletes) ──────────────

    match /abandoned_carts/{sessionId} {
      allow create, update: if true;
      allow read, delete:   if isAdmin();
    }

    // ── Customers (anyone can write post-payment, admin reads/deletes) ────────

    match /customers/{customerId} {
      allow create, update: if true;
      allow read, delete:   if isAdmin();
    }

    // ── Sofer profile edit requests ─────────────────────────────────────────

    match /sofer_edit_requests/{requestId} {
      // סופר יכול ליצור בקשה עבור עצמו בלבד
      allow create: if request.auth != null
                    && request.resource.data.soferId == request.auth.uid;

      // סופר יכול לקרוא את הבקשות שלו בלבד; אדמין קורא הכל
      allow read: if request.auth != null
                  && (resource.data.soferId == request.auth.uid || isAdmin());

      // רק אדמין יכול לעדכן/לאשר/לדחות
      allow update, delete: if isAdmin();
    }

    // ── Soferim applications ────────────────────────────────────────────────

    match /soferim_applications/{id} {
      allow create: if true;             // public application form
      allow read, update, delete: if isAdmin();
    }

    // ── Shluchim applications ───────────────────────────────────────────────

    match /shluchim_applications/{id} {
      allow create: if true;             // public application form
      allow read, update, delete: if isAdmin();
    }

    // ── Personal store requests (sofer → admin approval flow) ───────────────

    match /rabbi_requests/{id} {
      // Any signed-in sofer can submit a request for themselves
      allow create: if isSignedIn()
                    && request.resource.data.soferUid == request.auth.uid;
      // Sofer can read their own requests; admin reads all
      allow read: if isSignedIn()
                  && (resource.data.soferUid == request.auth.uid || isAdmin());
      // Only admin can approve/reject
      allow update, delete: if isAdmin();
    }

    // ── Newsletter subscriptions ─────────────────────────────────────────────

    match /newsletter/{id} {
      allow create: if true;             // anyone can subscribe
      allow read, update, delete: if isAdmin();
    }

    // ── Testimonials ────────────────────────────────────────────────────────

    match /testimonials/{id} {
      allow read: if true;               // homepage reads active testimonials publicly
      allow write: if isAdmin();         // only admins can add/edit/delete
    }

    // ── Ops users (internal team) ───────────────────────────────────────────

    match /opsUsers/{id} {
      allow read, write: if isAdmin();
    }
  }
}

import { initializeApp, cert } from 'firebase-admin/app';
import { getFirestore } from 'firebase-admin/firestore';
import { createReadStream } from 'fs';
import { createInterface } from 'readline';
import { fileURLToPath } from 'url';
import { dirname, join } from 'path';

const __dirname = dirname(fileURLToPath(import.meta.url));

// חיבור Firebase
const serviceAccount = JSON.parse(
  await import('fs').then(fs => fs.promises.readFile(join(__dirname, 'serviceAccount.json'), 'utf8'))
);
initializeApp({ credential: cert(serviceAccount) });
const db = getFirestore();

function readCSV(filePath) {
  return new Promise((resolve, reject) => {
    const rows = [];
    let headers = [];
    const rl = createInterface({ input: createReadStream(filePath, 'utf8') });
    rl.on('line', (line) => {
      if (!line.trim()) return;
      const values = line.split(',');
      if (headers.length === 0) {
        headers = values.map(h => h.trim().toLowerCase().replace(/"/g, ''));
      } else {
        const row = {};
        headers.forEach((h, i) => {
          row[h] = (values[i] || '').trim().replace(/"/g, '');
        });
        rows.push(row);
      }
    });
    rl.on('close', () => resolve(rows));
    rl.on('error', reject);
  });
}

async function importProducts() {
  const csvPath = join(__dirname, 'products_import.csv');
  console.log('קורא קובץ:', csvPath);
  const rows = await readCSV(csvPath);
  console.log(`נמצאו ${rows.length} שורות`);

  let added = 0, updated = 0, skipped = 0;

  for (const row of rows) {
    const name = row['name'] || row['שם'] || '';
    const price = parseFloat(row['price'] || row['מחיר'] || '0');

    if (!name || isNaN(price) || price <= 0) {
      skipped++;
      continue;
    }

    const data = {
      name,
      cat: row['cat'] || row['קטגוריה'] || 'כללי',
      price,
      status: 'active',
    };

    if (row['was']) data.was = parseFloat(row['was']);
    if (row['desc']) data.desc = row['desc'];
    if (row['badge']) data.badge = row['badge'];
    if (row['days']) data.days = row['days'];
    if (row['imgurl'] || row['image_url']) data.imgUrl = row['imgurl'] || row['image_url'];
    if (row['imgurl2']) data.imgUrl2 = row['imgurl2'];
    if (row['imgurl3']) data.imgUrl3 = row['imgurl3'];
    if (row['soferid']) data.soferId = row['soferid'];

    const existingId = row['id'] || '';

    try {
      if (existingId) {
        await db.collection('products').doc(existingId).update(data);
        updated++;
        if (updated % 10 === 0) console.log(`עודכנו: ${updated}`);
      } else {
        data.createdAt = new Date();
        await db.collection('products').add(data);
        added++;
        if (added % 10 === 0) console.log(`נוספו: ${added}`);
      }
    } catch (e) {
      console.error(`שגיאה במוצר "${name}":`, e.message);
      skipped++;
    }
  }

  console.log(`\nסיום!`);
  console.log(`נוספו: ${added}`);
  console.log(`עודכנו: ${updated}`);
  console.log(`דולגו: ${skipped}`);
  process.exit(0);
}

importProducts().catch(e => { console.error(e); process.exit(1); });
